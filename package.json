{
  "name": "ps-vscode-cpm",
  "displayName": "ps-vscode-cpm",
  "description": "Manage custom pages in PowerSchool",
  "version": "0.6.1",
  "publisher": "zuvy",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zuvy/ps-vscode-cpm.git"
  },
  "main": "./extension.js",
  "contributes": {
    "commands": [

      {
        "command": "ps-vscode-cpm.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ps-vscode-cpm.downloadFile",
        "title": "Download File"
      },
      {
        "command": "ps-vscode-cpm.publishFile",
        "title": "Publish to PowerSchool",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "ps-vscode-cpm.publishCurrentFile",
        "title": "ps-vscode-cpm: Publish Current File"
      },
      {
        "command": "ps-vscode-cpm.deleteFileFromServer",
        "title": "Delete from PowerSchool",
        "icon": "$(trash)"
      },
      {
        "command": "ps-vscode-cpm.createNewFile",
        "title": "ps-vscode-cpm: Create New File",
        "icon": "$(new-file)"
      },
      {
        "command": "ps-vscode-cpm.publishNewFile",
        "title": "ps-vscode-cpm: Publish New File to PowerSchool",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "ps-vscode-cpm.showCurrentFilePath",
        "title": "ps-vscode-cpm: Show File Path Info",
        "icon": "$(info)"
      },
      {
        "command": "ps-vscode-cpm.insertSnippet",
        "title": "ps-vscode-cpm: Insert Code Snippet",
        "icon": "$(code)"
      },
      {
        "command": "ps-vscode-cpm.insertSnippet.box_round",
        "title": "ps-vscode-cpm: Insert Box-Round Div"
      },
      {
        "command": "ps-vscode-cpm.insertSnippet.calendar",
        "title": "Date Picker Widget"
      },
      {
        "command": "ps-vscode-cpm.insertSnippet.dialog",
        "title": "Dialog Link"
      },
      {
        "command": "ps-vscode-cpm.insertSnippet.dynamic_tabs",
        "title": "Dynamic Tabs"
      },
      {
        "command": "ps-vscode-cpm.insertSnippet.jquery_function",
        "title": "jQuery Function Block"
      },
      {
        "command": "ps-vscode-cpm.insertSnippet.form",
        "title": "PowerSchool Form"
      },
      {
        "command": "ps-vscode-cpm.insertSnippet.table",
        "title": "Data Table"
      },
      {
        "command": "ps-vscode-cpm.insertSnippet.tlist_sql",
        "title": "TList SQL Block"
      },
      {
        "command": "ps-vscode-cpm.insertSnippet.collapsible_box",
        "title": "Collapsible Box"
      },
      {
        "command": "ps-vscode-cpm.insertSnippet.if_block",
        "title": "If/Else Block"
      },
      {
        "command": "ps-vscode-cpm.insertSnippet.student_info",
        "title": "Student Info Tags"
      },
      {
        "command": "ps-vscode-cpm.insertSnippet.breadcrumb",
        "title": "Breadcrumb Navigation"
      },
      {
        "command": "ps-vscode-cpm.createTemplate.admin",
        "title": "Admin Page"
      },
      {
        "command": "ps-vscode-cpm.createTemplate.adminStudentPage",
        "title": "Admin Student Page"
      },
      {
        "command": "ps-vscode-cpm.createTemplate.teacher",
        "title": "Teacher Page"
      },
      {
        "command": "ps-vscode-cpm.createTemplate.teacherBackpack",
        "title": "Teacher Backpack Page"
      },
      {
        "command": "ps-vscode-cpm.createTemplate.parentPortal",
        "title": "Parent Portal Page"
      },
      {
        "command": "ps-vscode-cpm.openSettings",
        "title": "ps-vscode-cpm: Configure Server Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "ps-vscode-cpm.testJsonEndpoint",
        "title": "ps-vscode-cpm: Test JSON Endpoint",
        "icon": "$(json)"
      },
      {
        "command": "ps-vscode-cpm.setupWebRoot",
        "title": "ps-vscode-cpm: Setup Plugin Web Root Directory"
      },
      {
        "command": "ps-vscode-cpm.packagePlugin",
        "title": "ps-vscode-cpm: Package Plugin as ZIP",
        "icon": "$(package)"
      },
      {
        "command": "ps-vscode-cpm.noJsonFiles",
        "title": "ps-vscode-cpm: No JSON Files"
      },
      {
        "command": "ps-vscode-cpm.scaffoldWithMcp",
        "title": "ps-vscode-cpm: Scaffold with ps-mcp"
      },
      {
        "command": "ps-vscode-cpm.compareWithOriginal",
        "title": "Compare with Original",
        "category": "PowerSchool CPM"
      }
    ],
    "views": {
      "ps-vscode-cpm": [
        {
          "id": "ps-vscode-cpm-explorer",
          "name": "PowerSchool Files"
        },
        {
          "id": "ps-vscode-cpm-commands",
          "name": "Commands"
        },
        {
          "id": "ps-vscode-cpm-server-info",
          "name": "Server Info"
        },
        {
          "id": "ps-vscode-cpm-templates",
          "name": "Templates"
        },
        {
          "id": "ps-vscode-cpm-snippets",
          "name": "Snippets"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ps-vscode-cpm",
          "title": "ps-vscode-cpm",
          "icon": "$(server-environment)"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "ps-vscode-cpm.noJsonFiles",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "ps-vscode-cpm.refresh",
          "when": "view == ps-vscode-cpm-explorer",
          "group": "navigation"
        },
        {
          "command": "ps-vscode-cpm.openSettings",
          "when": "view == ps-vscode-cpm-explorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ps-vscode-cpm.publishFile",
          "when": "view == ps-vscode-cpm-explorer && (viewItem == file || viewItem == file-custom || viewItem == file-plugin)",
          "group": "inline"
        },
        {
          "command": "ps-vscode-cpm.compareWithOriginal",
          "when": "view == ps-vscode-cpm-explorer && (viewItem == file-custom || viewItem == file-plugin)",
          "group": "ps-vscode-cpm@2"
        },
        {
          "command": "ps-vscode-cpm.deleteFileFromServer",
          "when": "view == ps-vscode-cpm-explorer && viewItem == file-custom",
          "group": "ps-vscode-cpm@3"
        }
      ],
      "explorer/context": [
        {
          "command": "ps-vscode-cpm.scaffoldWithMcp",
          "when": "explorerResourceIsFolder && resourcePath =~ /queries_root|user_schema_root|permissions_root/",
          "group": "ps-vscode-cpm@1"
        }
      ]
    },
    "configuration": {
      "title": "ps-vscode-cpm",
      "properties": {
        "ps-vscode-cpm.serverUrl": {
          "type": "string",
          "default": "",
          "description": "PowerSchool server URL (e.g., https://pstest.yourschool.org)",
          "scope": "window"
        },
        "ps-vscode-cpm.username": {
          "type": "string",
          "default": "",
          "description": "PowerSchool username for CPM session authentication (fallback for CPM APIs)",
          "scope": "window"
        },
        "ps-vscode-cpm.password": {
          "type": "string",
          "default": "",
          "description": "PowerSchool password for CPM session authentication (fallback for CPM APIs)",
          "scope": "window"
        },
        "ps-vscode-cpm.pluginWebRoot": {
          "type": "string",
          "default": "web_root",
          "description": "Path to web_root directory relative to workspace. Options: \"\" (workspace is plugin root), \"web_root\" (workspace/web_root), \"src\" (workspace/src/web_root), or \"src/web_root\" (explicit path)."
        },
        "ps-vscode-cpm.autoSync": {
          "type": "boolean",
          "default": true,
          "description": "Automatically sync workspace directory when workspace opens"
        },
        "ps-vscode-cpm.maxDepth": {
          "type": "number",
          "default": 5,
          "description": "Maximum folder depth to sync"
        },
        "ps-plugin.workspaceRoot": {
          "type": "string",
          "default": "",
          "description": "Relative path from the VS Code workspace folder to the plugin artifacts root (the directory containing plugin.xml). Use \"src\" for src-based layouts, \"\" (empty string) for flat layouts where plugin.xml is at the workspace root. Read by both ps-vscode-cpm and ps-mcp.",
          "scope": "resource"
        },
        "ps-vscode-cpm.contentRoot": {
          "type": "string",
          "enum": ["web_root", "queries_root", "user_schema_root"],
          "default": "web_root",
          "description": "Which CPM content root to browse. Use 'web_root' for standard pages, 'queries_root' or 'user_schema_root' for extended schema."
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint ."
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.104.0",
    "eslint": "^9.34.0"
  }
}
